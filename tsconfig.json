{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "@hawk/eyrie": ["../eyrie/src/index.ts"],
      "@hawk/eyrie/*": ["../eyrie/src/*"]
    }
  },
  "include": ["src/**/*", "src/types/globals.d.ts"],
  "exclude": ["node_modules", "dist"]
}
